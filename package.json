{
  "name": "@elbc/beepify",
  "version": "0.3.0",
  "description": "Turn AI coding agent events into phone & desktop notifications",
  "type": "module",
  "bin": { "beepify": "dist/cli/index.js" },
  "files": ["dist", "config.example.toml", "README.md", "README.zh-CN.md", "LICENSE"],
  "engines": { "node": ">=18" },
  "keywords": [
    "claude-code",
    "notifications",
    "push",
    "bark",
    "ntfy",
    "cli",
    "hooks",
    "ai-agent"
  ],
  "author": "CRENH",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "git+https://github.com/CRENH/Beepify.git" },
  "homepage": "https://github.com/CRENH/Beepify#readme",
  "bugs": { "url": "https://github.com/CRENH/Beepify/issues" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": { "smol-toml": "^1.3.0" },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
